---
import Layout from '../layouts/Layout.astro';
import CatalogHeader from '../components/CatalogHeader.astro';
import CatalogTabs from '../components/CatalogTabs.astro';
import CatalogFilters from '../components/CatalogFilters.astro';
---

<Layout>
  <main class="page__inner">
    <CatalogHeader />
    <CatalogTabs />
    <CatalogFilters />
    <div id="catalog" class="catalog" aria-live="polite">
      <p class="catalog-message catalog-message--loading">Chargement du catalogue…</p>
    </div>
  </main>
</Layout>

<script>
  import {
    applyFilters,
    applySpiritFilters,
    buildFilterOptions,
    CATALOG_SECTION_SPIRITS,
    CATALOG_SECTION_WINES,
    countSectionTotal,
    EMPTY_FILTERS,
    filtersFromSearchParams,
    filtersToSearchParams,
    hasActiveFilters,
    isWinesSection,
    type CatalogFilters,
    type CatalogSectionOption,
    type RegionGroupOption,
  } from '../lib/filters';
  import { formatCountryName, formatReferenceCount, formatRegionName } from '../lib/format';
  import {
    fetchCatalog,
    fetchSpiritsCatalog,
    groupSpiritsByTypeAndCategory,
    groupWinesByCountryAndRegion,
  } from '../lib/sheets';
  import { renderCatalog, renderCatalogParts, renderError, renderSpiritsCatalog } from '../lib/render';
  import type { CatalogData, SpiritsCatalogData } from '../lib/types';

  const sheetId = import.meta.env.PUBLIC_GOOGLE_SHEET_ID;
  const spiritsSheetGid =
    import.meta.env.PUBLIC_GOOGLE_SHEET_SPIRITS_GID || '337014678';
  const catalogEl = document.getElementById('catalog');
  const countEl = document.getElementById('reference-count');
  const tabsEl = document.getElementById('catalog-tabs');
  const tabButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.catalog-tabs__tab'),
  );
  const filtersEl = document.getElementById('catalog-filters');
  const toggleEl = document.getElementById('filter-toggle') as HTMLButtonElement | null;
  const panelEl = document.getElementById('filter-panel');
  const badgeEl = document.getElementById('filter-active-badge');
  const searchEl = document.getElementById('filter-search') as HTMLInputElement | null;
  const catalogSectionEl = document.getElementById('filter-catalog') as HTMLSelectElement | null;
  const countryFieldEl = document.getElementById('filter-country-field');
  const regionFieldEl = document.getElementById('filter-region-field');
  const countryEl = document.getElementById('filter-country') as HTMLSelectElement | null;
  const regionEl = document.getElementById('filter-region') as HTMLSelectElement | null;
  const typeEl = document.getElementById('filter-type') as HTMLSelectElement | null;
  const typeLabelEl = document.getElementById('filter-type-label');
  const resetEl = document.getElementById('filter-reset') as HTMLButtonElement | null;
  const statusEl = document.getElementById('filter-status');

  let catalogData: CatalogData | null = null;
  let spiritsData: SpiritsCatalogData | null = null;
  let filters: CatalogFilters = { ...EMPTY_FILTERS };

  function readFilters(): CatalogFilters {
    return {
      catalogSection: catalogSectionEl?.value || CATALOG_SECTION_WINES,
      search: searchEl?.value ?? '',
      country: countryEl?.value ?? '',
      region: regionEl?.value ?? '',
      type: typeEl?.value ?? '',
    };
  }

  function applyFiltersToForm(next: CatalogFilters) {
    if (searchEl) searchEl.value = next.search;
    if (catalogSectionEl) catalogSectionEl.value = next.catalogSection;
    if (countryEl) countryEl.value = next.country;
    if (regionEl) regionEl.value = next.region;
    if (typeEl) typeEl.value = next.type;
    syncCatalogTabs(next.catalogSection);
  }

  function syncFiltersToUrl() {
    const params = filtersToSearchParams(filters);
    const query = params.toString();
    const nextUrl = query ? `${location.pathname}?${query}` : location.pathname;
    const currentUrl = `${location.pathname}${location.search}`;

    if (nextUrl !== currentUrl) {
      history.replaceState(null, '', nextUrl);
    }
  }

  function applyFiltersFromUrl() {
    filters = filtersFromSearchParams(new URLSearchParams(location.search));
    applyFiltersToForm(filters);
  }

  function populateSelect(
    select: HTMLSelectElement,
    options: string[],
    placeholder: string,
    selected: string,
    formatLabel: (value: string) => string = (value) => value,
  ) {
    const current = selected;
    select.innerHTML = '';

    const defaultOption = document.createElement('option');
    defaultOption.value = '';
    defaultOption.textContent = placeholder;
    select.appendChild(defaultOption);

    for (const option of options) {
      const item = document.createElement('option');
      item.value = option;
      item.textContent = formatLabel(option);
      select.appendChild(item);
    }

    select.value = options.includes(current) ? current : '';
  }

  function populateCatalogSelect(
    select: HTMLSelectElement,
    options: CatalogSectionOption[],
    selected: string,
  ) {
    select.innerHTML = '';

    for (const option of options) {
      const item = document.createElement('option');
      item.value = option.value;
      item.textContent = option.label;
      select.appendChild(item);
    }

    const values = options.map((option) => option.value);
    select.value = values.includes(selected) ? selected : CATALOG_SECTION_WINES;
  }

  function populateRegionSelect(
    select: HTMLSelectElement,
    groups: RegionGroupOption[],
    placeholder: string,
    selected: string,
  ) {
    select.innerHTML = '';

    const defaultOption = document.createElement('option');
    defaultOption.value = '';
    defaultOption.textContent = placeholder;
    select.appendChild(defaultOption);

    const allRegions: string[] = [];
    const useOptgroups = groups.length > 1;

    for (const group of groups) {
      const container = useOptgroups
        ? (() => {
            const optgroup = document.createElement('optgroup');
            optgroup.label = formatCountryName(group.country);
            select.appendChild(optgroup);
            return optgroup;
          })()
        : select;

      for (const region of group.regions) {
        const item = document.createElement('option');
        item.value = region;
        item.textContent = formatRegionName(region);
        container.appendChild(item);
        allRegions.push(region);
      }
    }

    select.value = allRegions.includes(selected) ? selected : '';
  }

  function updateSectionFields(showingWines: boolean) {
    if (countryFieldEl) countryFieldEl.hidden = !showingWines;
    if (regionFieldEl) regionFieldEl.hidden = !showingWines;
    if (typeLabelEl) typeLabelEl.textContent = showingWines ? 'Type' : 'Catégorie';
    if (searchEl) {
      searchEl.placeholder = showingWines
        ? 'Domaine, cuvée, cépage, appellation…'
        : 'Distillerie, étiquette, origine…';
    }
  }

  function syncCatalogTabs(section: string) {
    for (const tab of tabButtons) {
      const isActive = tab.dataset.catalog === section;
      tab.classList.toggle('is-active', isActive);
      tab.setAttribute('aria-selected', String(isActive));
      tab.tabIndex = isActive ? 0 : -1;
    }
  }

  function setCatalogSection(section: string, { resetSubFilters = true } = {}) {
    const next =
      section === CATALOG_SECTION_SPIRITS ? CATALOG_SECTION_SPIRITS : CATALOG_SECTION_WINES;

    if (catalogSectionEl) catalogSectionEl.value = next;
    syncCatalogTabs(next);

    if (resetSubFilters) {
      if (countryEl) countryEl.value = '';
      if (regionEl) regionEl.value = '';
      if (typeEl) typeEl.value = '';
    }

    updateCatalog();
  }

  function updateFilterOptions() {
    if (!catalogData || !catalogSectionEl || !countryEl || !regionEl || !typeEl) return;

    const spirits = spiritsData?.spirits ?? [];
    const options = buildFilterOptions(catalogData.wines, spirits, filters);
    const showingWines = isWinesSection(filters);

    populateCatalogSelect(catalogSectionEl, options.catalogSections, filters.catalogSection);
    syncCatalogTabs(filters.catalogSection);
    updateSectionFields(showingWines);

    if (showingWines) {
      populateSelect(countryEl, options.countries, 'Tous les pays', filters.country, formatCountryName);
      populateRegionSelect(regionEl, options.regionsByCountry, 'Toutes les régions', filters.region);
    } else {
      countryEl.value = '';
      regionEl.value = '';
    }

    populateSelect(
      typeEl,
      options.types,
      showingWines ? 'Tous les types' : 'Toutes les catégories',
      filters.type,
    );
  }

  function updateCatalog() {
    if (!catalogData || !catalogEl) return;

    const fromForm = readFilters();
    const countryReady = Boolean(countryEl && countryEl.options.length > 1);
    const regionReady = Boolean(regionEl && regionEl.options.length > 1);
    const typeReady = Boolean(typeEl && typeEl.options.length > 1);

    filters = {
      catalogSection: fromForm.catalogSection,
      search: fromForm.search,
      country: countryReady ? fromForm.country : filters.country,
      region: regionReady ? fromForm.region : filters.region,
      type: typeReady ? fromForm.type : filters.type,
    };

    updateFilterOptions();
    filters = readFilters();
    syncFiltersToUrl();

    const spirits = spiritsData?.spirits ?? [];
    const filteredWines = applyFilters(catalogData.wines, filters);
    const filteredSpirits = applySpiritFilters(spirits, filters);
    const countries = groupWinesByCountryAndRegion(filteredWines);
    const spiritTypes = groupSpiritsByTypeAndCategory(filteredSpirits);

    const winesHtml = renderCatalog(countries, '');
    const spiritsHtml = renderSpiritsCatalog(spiritTypes);
    const emptyMessage = hasActiveFilters(filters)
      ? 'Aucune référence ne correspond à vos critères.'
      : undefined;

    catalogEl.innerHTML = renderCatalogParts({
      winesHtml,
      spiritsHtml,
      showWinesHeading: false,
      showSpiritsHeading: false,
      emptyMessage,
    });

    const filteredTotal = filteredWines.length + filteredSpirits.length;
    const sectionTotal = countSectionTotal(catalogData.wines, spirits, filters.catalogSection);

    if (countEl) {
      countEl.textContent = formatReferenceCount(filteredTotal, sectionTotal);
    }

    if (statusEl) {
      statusEl.textContent = hasActiveFilters(filters)
        ? `${filteredTotal} résultat${filteredTotal > 1 ? 's' : ''}`
        : '';
    }

    if (resetEl) {
      resetEl.hidden = !hasActiveFilters(filters);
    }

    updateFilterToggle();
  }

  function updateFilterToggle() {
    const isOpen = Boolean(panelEl && !panelEl.hidden);

    if (toggleEl) {
      toggleEl.setAttribute('aria-expanded', String(isOpen));
    }

    if (badgeEl) {
      badgeEl.hidden = !hasActiveFilters(filters) || isOpen;
    }
  }

  function toggleFilterPanel() {
    if (!panelEl) return;
    panelEl.hidden = !panelEl.hidden;
    updateFilterToggle();
  }

  function resetFilters() {
    const currentSection = catalogSectionEl?.value || CATALOG_SECTION_WINES;
    if (searchEl) searchEl.value = '';
    if (countryEl) countryEl.value = '';
    if (regionEl) regionEl.value = '';
    if (typeEl) typeEl.value = '';
    filters = { ...EMPTY_FILTERS, catalogSection: currentSection };
    if (catalogSectionEl) catalogSectionEl.value = currentSection;
    syncCatalogTabs(currentSection);
    updateCatalog();
  }

  function bindFilterEvents() {
    toggleEl?.addEventListener('click', toggleFilterPanel);
    searchEl?.addEventListener('input', updateCatalog);

    for (const tab of tabButtons) {
      tab.addEventListener('click', () => {
        const section = tab.dataset.catalog || CATALOG_SECTION_WINES;
        if (section === (catalogSectionEl?.value || CATALOG_SECTION_WINES)) return;
        setCatalogSection(section);
      });
    }

    catalogSectionEl?.addEventListener('change', () => {
      setCatalogSection(catalogSectionEl.value);
    });
    countryEl?.addEventListener('change', () => {
      if (regionEl) regionEl.value = '';
      updateCatalog();
    });
    regionEl?.addEventListener('change', updateCatalog);
    typeEl?.addEventListener('change', updateCatalog);
    resetEl?.addEventListener('click', resetFilters);

    window.addEventListener('popstate', () => {
      applyFiltersFromUrl();
      updateCatalog();
    });
  }

  async function loadCatalog() {
    if (!catalogEl) return;

    try {
      const [wines, spirits] = await Promise.all([
        fetchCatalog(sheetId),
        fetchSpiritsCatalog(sheetId, spiritsSheetGid).catch(() => null),
      ]);

      catalogData = wines;
      spiritsData = spirits;

      if (tabsEl) tabsEl.hidden = false;
      if (filtersEl) filtersEl.hidden = false;
      bindFilterEvents();
      applyFiltersFromUrl();
      updateCatalog();
    } catch (error) {
      const message =
        error instanceof Error ? error.message : 'Une erreur est survenue lors du chargement.';
      catalogEl.innerHTML = renderError(message);
    }
  }

  loadCatalog();
</script>
